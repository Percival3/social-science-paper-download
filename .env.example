# Paper Harvester - Sci-Hub Edition
# Configuration file
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED CONFIGURATION
# =============================================================================

# Your email for Crossref API (required)
# Crossref requires this for polite pool access
CROSSREF_MAILTO=your-email@example.com

# User-Agent string for HTTP requests
USER_AGENT=paper-harvester/1.0 (mailto:your-email@example.com)

# =============================================================================
# SCI-HUB MIRROR CONFIGURATION
# =============================================================================

# Comma-separated list of Sci-Hub mirrors, in priority order
# These are current mirrors as of 2024, but they change frequently
# Update this list as needed
SCIHUB_MIRRORS=https://sci-hub.al,https://sci-hub.se,https://sci-hub.st,https://sci-hub.ru,https://sci-hub.wf,https://sci-hub.ren

# Timeout for individual HTTP requests (seconds)
SCIHUB_TIMEOUT=30

# Number of retries per mirror before switching
SCIHUB_RETRY=3

# Cooldown time for failed mirrors (seconds)
SCIHUB_MIRROR_COOLDOWN=300

# =============================================================================
# OFFICIAL SOURCE CONFIGURATION (Optional)
# =============================================================================

# Browser-like User-Agent for official publisher/source downloads.
# Useful for NBER official PDFs and similar working-paper sources.
OFFICIAL_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0 Safari/537.36

# Optional cookie copied from a browser session on nber.org.
# Leave empty unless you are downloading from an authenticated/institutional session.
# NBER_COOKIE=

# Optional cookie copied from a browser session on ssrn.com / papers.ssrn.com.
# SSRN public downloads are tried first; this cookie is only used as a second
# official-source attempt before Sci-Hub fallback.
# SSRN_COOKIE=

# =============================================================================
# SYSTEM CONFIGURATION
# =============================================================================

# Root directory for all data
DATA_DIR=data

# Rate limiting: requests per minute
REQUESTS_PER_MINUTE=10

# Concurrent downloads limit
CONCURRENT_DOWNLOADS=3

# Maximum retries per DOI across all mirrors
MAX_RETRIES_PER_DOI=5

# =============================================================================
# PROXY CONFIGURATION (Optional)
# =============================================================================

# Uncomment and set if you need to use a proxy
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
